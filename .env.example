PORT=5000

# Local MongoDB:
# MONGODB_URI=mongodb://127.0.0.1:27017/Pahadi_link
#
# MongoDB Atlas (required for GitHub Pages / hosted API):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/Pahadi_link?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/Pahadi_link

JWT_SECRET=pahadlink-dev-secret-change-me
JWT_EXPIRES_IN=7d
NODE_ENV=development
# GOOGLE_CLIENT_ID=
ADMIN_EMAIL=admin@pahadlink.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Order emails (Nodemailer). Without SMTP, emails are logged to the API console.
# Gmail: App Password after 2FA.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password
# MAIL_FROM="PahadLink <your@gmail.com>"
# ORDER_NOTIFY_EMAIL=admin@pahadlink.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
ORDER_NOTIFY_EMAIL=

# Firebase (project: pahadlink / pahadlink-56803)
FIREBASE_PROJECT_ID=pahadlink-56803
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=pahadlink-56803.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=pahadlink-56803
VITE_FIREBASE_STORAGE_BUCKET=pahadlink-56803.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=1034496959291
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Optional: Google Maps Geocoding (same Google Cloud project). Falls back to OpenStreetMap.
# VITE_GOOGLE_MAPS_API_KEY=

# Frontend production build (optional local file: .env.production)
# VITE_API_URL=https://YOUR-API-HOST.onrender.com/api
